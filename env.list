# Docker entrypoint variables
#
# These are consumed by this image's Dockerfile entrypoint and translated into
# sim_vehicle.py arguments.

# SITL instance number. Affects default ports and instance-specific state.
INSTANCE=0

# MAVLink system ID passed to sim_vehicle.py as --sysid.
SYSID=1

# ArduPilot vehicle target passed to sim_vehicle.py as --vehicle.
# Common values in ./ardupilot include ArduCopter, ArduPlane, Rover, ArduSub,
# Helicopter, Blimp, AntennaTracker, and sitl_periph_universal.
VEHICLE=ArduCopter

# Simulation frame/model passed to sim_vehicle.py as --frame.
# Examples: quad, hexa, plane, rover, rover-skid, vectored.
FRAME=quad

# Directory convention for runtime-mounted SITL model and parameter files.
# Relative PARAM_FILE entries are resolved under this directory.
# If $SITL_CONFIG_DIR/vehicleinfo.json exists, the wrapper uses it by default.
SITL_CONFIG_DIR=/configs

# Optional custom vehicleinfo.json path. Relative paths are resolved under
# SITL_CONFIG_DIR. If unset, the wrapper checks for vehicleinfo.json inside
# SITL_CONFIG_DIR.
# VEHICLEINFO_JSON=vehicleinfo.json

# Optional physics model override passed to sim_vehicle.py as --model.
# For JSON-backed copter models, include the frame prefix and mounted file path.
# Overrides any model found in a mounted vehicleinfo.json.
# Example: MODEL=quad:/configs/my_quad.json
# MODEL=

# Optional parameter file layered with --add-param-file.
# Relative paths are resolved under SITL_CONFIG_DIR.
# Overrides any default_params_filename entries in a mounted vehicleinfo.json.
# Example: PARAM_FILE=my_quad.parm
# PARAM_FILE=

# Optional Lua script copied into ArduPilot's working scripts/ directory before
# SITL starts. Relative paths are resolved under SITL_CONFIG_DIR. If
# $SITL_CONFIG_DIR/scripts/ exists, that directory is copied too.
# ArduPilot only runs scripts when scripting is enabled by params, usually
# SCR_ENABLE=1. SITL pose injection via sim:set_pose also needs AHRS_EKF_TYPE=10.
# Example: LUA_SCRIPT=initial-state.lua
# LUA_SCRIPT=

# Optional QGC WPL 110 mission file loaded by the image-provided Lua mission
# loader. Relative paths are resolved under SITL_CONFIG_DIR. The wrapper stages
# the file into the ArduPilot working tree and installs load-mission.lua.
# ArduPilot only runs the loader when scripting is enabled by params, usually
# SCR_ENABLE=1.
# Example: MISSION_FILE=missions/simple-copter.waypoints
# MISSION_FILE=

# Custom home latitude used in --custom-location.
LAT=37.1971467

# Custom home longitude used in --custom-location.
LON=-80.5780381

# Custom home altitude in meters used in --custom-location.
ALT=618

# Custom home heading in degrees used in --custom-location.
DIR=55

# Simulation speed multiplier passed to sim_vehicle.py as --speedup.
SPEEDUP=1

# Optional extra MAVProxy arguments passed through sim_vehicle.py with
# -m/--mavproxy-args. Leave unset to use sim_vehicle.py's MAVProxy defaults.
# PROXY=--out=udp:127.0.0.1:14550 --out=tcpin:0.0.0.0:5761


# sim_vehicle.py environment variables
#
# These are read directly by ./ardupilot/Tools/autotest/sim_vehicle.py.
# Leave optional variables commented unless you want to override the defaults.

# Path to a user locations.txt file. Overrides the default location lookup file.
# ARDUPILOT_LOCATIONS=/home/ardupilot/.config/ardupilot/locations.txt

# Base config directory used when ARDUPILOT_LOCATIONS is unset. sim_vehicle.py
# looks for locations.txt at $XDG_CONFIG_DIR/ardupilot/locations.txt.
# XDG_CONFIG_DIR=/home/ardupilot/.config

# Home directory used to derive the default config path when XDG_CONFIG_DIR is
# unset: $HOME/.config/ardupilot/locations.txt.
# HOME=/home/ardupilot

# Used on graphical hosts, especially macOS, to decide whether terminal windows
# can be launched for debugger sessions.
# DISPLAY=:0

# Internal session token generated by sim_vehicle.py and used to clean up child
# processes. Usually do not set this yourself.
# SIM_VEHICLE_SESSION=


# Helper environment variables used by sim_vehicle.py dependencies
#
# These are read by Tools/autotest/pysim/util.py or run_in_terminal_window.sh,
# which sim_vehicle.py calls for builds, SITL launch, MAVProxy, and terminals.

# MAVProxy executable to run. Defaults to mavproxy.py.
# MAVPROXY_CMD=mavproxy.py

# C++ compiler override used when running sim_vehicle.py with --asan.
# CXX=clang++

# C compiler override used when running sim_vehicle.py with --asan.
# CC=clang

# AddressSanitizer runtime options. When --asan is used, ArduPilot appends its
# own log_path, symbolize, and verbosity settings to any existing value.
# ASAN_OPTIONS=

# Python import path inherited by MAVProxy. sim_vehicle.py prepends ArduPilot's
# local mavproxy_modules path before launching MAVProxy.
# PYTHONPATH=

# Preferred terminal launcher for Tools/autotest/run_in_terminal_window.sh.
# Examples: "screen -D -m", "gnome-terminal -e", "konsole -e".
# SITL_RITW_TERMINAL=screen -D -m

# Whether run_in_terminal_window.sh should start xterm minimized when possible.
# Defaults to 1 when unset.
# SITL_RITW_MINIMIZE=1

# Temporary directory used by run_in_terminal_window.sh when creating wrapper
# scripts for SITL_RITW_TERMINAL.
# TMPDIR=/tmp

# Existing terminal session markers used by run_in_terminal_window.sh to decide
# whether it can open panes/windows inside tmux, screen, or zellij.
# TMUX=
# TMUX_PREFIX=
# STY=
# ZELLIJ=
